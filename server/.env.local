# .env Configuration Guide

# For LOCAL development with MongoDB running on your machine:
PORT=4000
MONGO_URI=mongodb://localhost:27017/ai_interview_platform
JWT_SECRET=dev_secret_key_change_in_production

# -----------------------------------------------
# ALTERNATIVE: Using MongoDB Atlas (Cloud)
# Uncomment below and replace with your credentials

# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/ai_interview_platform?retryWrites=true&w=majority
# JWT_SECRET=prod_secret_key_12345

# -----------------------------------------------
# NODE ENV
NODE_ENV=development

# -----------------------------------------------
# Optional: API Integration (for future use)
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...
